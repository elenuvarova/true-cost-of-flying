# Keep the build context tiny. The app only needs app.py, .streamlit/, data/processed/,
# and requirements.txt — everything below is offline-build tooling, caches, or dev cruft.

# Heavy offline-only data (NOT needed at runtime — ~500 MB of ERA5 cache etc.)
data/cache
data/raw
data/reference
data/processed/comparators_tracks

# Offline pipeline + docs + notebooks
batch
docs
notebooks
*.md

# Python / virtualenvs / build
.venv
.venv-app
__pycache__
**/__pycache__
*.pyc
*.pyo
.pytest_cache
.ruff_cache
.mypy_cache

# Secrets must never enter the image (analytics is a no-op without it anyway)
.streamlit/secrets.toml

# VCS / OS / editor
.git
.gitignore
.github
.DS_Store
.idea
.vscode
.python-version
